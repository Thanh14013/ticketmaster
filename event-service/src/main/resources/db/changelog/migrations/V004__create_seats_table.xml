<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!--
        Migration: V004 – Tạo bảng seats
        Author   : ticketmaster-dev

        Design notes:
          - Một row trong seats = 1 ghế của 1 Event cụ thể
          - seats thuộc về Event (không phải Venue), mỗi Event có bản copy riêng
          - status cập nhật realtime qua Kafka consumer từ booking-service
          - Index compound (event_id, status) là CRITICAL cho 2 query phổ biến nhất:
              1. SELECT * FROM seats WHERE event_id = ? (render seat map)
              2. COUNT(*) FROM seats WHERE event_id = ? AND status = 'AVAILABLE'
          - row + number uniquely identify 1 ghế trong 1 event + section
          - Bảng này có thể rất lớn (1 event × 50,000 ghế × nhiều events)
            → cân nhắc partitioning theo event_id trong tương lai
    -->

    <changeSet id="V004-create-seats-table" author="ticketmaster-dev">

        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="seats"/></not>
        </preConditions>

        <comment>Create seats table – ghế ngồi cụ thể cho từng event</comment>

        <createTable tableName="seats">

            <column name="id" type="VARCHAR(36)"
                    remarks="UUID v4, generated by application">
                <constraints primaryKey="true" nullable="false" primaryKeyName="pk_seats"/>
            </column>

            <column name="event_id" type="VARCHAR(36)"
                    remarks="FK → events.id – ghế thuộc event nào">
                <constraints nullable="false"
                             foreignKeyName="fk_seats_event"
                             references="events(id)"/>
            </column>

            <column name="section_id" type="VARCHAR(36)"
                    remarks="FK → seat_sections.id – ghế thuộc khu vực nào">
                <constraints nullable="false"
                             foreignKeyName="fk_seats_section"
                             references="seat_sections(id)"/>
            </column>

            <column name="row" type="VARCHAR(5)"
                    remarks="Hàng ghế: A, B, C... hoặc 1, 2, 3...">
                <constraints nullable="false"/>
            </column>

            <column name="number" type="VARCHAR(5)"
                    remarks="Số ghế trong hàng: 1, 2, 3...">
                <constraints nullable="false"/>
            </column>

            <column name="price" type="DECIMAL(10,2)"
                    remarks="Giá ghế này trong event cụ thể">
                <constraints nullable="false"/>
            </column>

            <column name="status" type="VARCHAR(20)"
                    defaultValue="AVAILABLE"
                    remarks="AVAILABLE | LOCKED | BOOKED – cập nhật qua Kafka">
                <constraints nullable="false"/>
            </column>

        </createTable>

        <!-- ─────────────────────────────────────────────────
             Indexes – CRITICAL cho performance seat map API
        ──────────────────────────────────────────────────── -->

        <!-- Query 1: SELECT * FROM seats WHERE event_id = ? (seat map render) -->
        <createIndex tableName="seats" indexName="idx_seats_event_id">
            <column name="event_id"/>
        </createIndex>

        <!-- Query 2: WHERE event_id = ? AND status = 'AVAILABLE' (count available) -->
        <createIndex tableName="seats" indexName="idx_seats_event_status">
            <column name="event_id"/>
            <column name="status"/>
        </createIndex>

        <!-- Query 3: WHERE event_id = ? AND section_id = ? (section-level seat map) -->
        <createIndex tableName="seats" indexName="idx_seats_event_section">
            <column name="event_id"/>
            <column name="section_id"/>
        </createIndex>

        <!-- ─────────────────────────────────────────────────
             Constraints
        ──────────────────────────────────────────────────── -->

        <!-- Unique: không thể có 2 ghế cùng hàng + số trong cùng event + section -->
        <addUniqueConstraint
                tableName="seats"
                columnNames="event_id, section_id, row, number"
                constraintName="uq_seats_event_section_row_number"/>

        <!-- CHECK: status hợp lệ -->
        <sql>
            ALTER TABLE seats
                ADD CONSTRAINT chk_seats_status
                    CHECK (status IN ('AVAILABLE', 'LOCKED', 'BOOKED'));
        </sql>

        <!-- CHECK: giá không âm -->
        <sql>
            ALTER TABLE seats
                ADD CONSTRAINT chk_seats_price
                    CHECK (price >= 0);
        </sql>

    </changeSet>

</databaseChangeLog>