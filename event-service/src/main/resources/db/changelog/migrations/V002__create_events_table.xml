<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!--
        Migration: V002 – Tạo bảng events
        Author   : ticketmaster-dev

        Design notes:
          - venue_name được denormalize để tránh JOIN khi search/list
          - available_seats là cached counter, cập nhật qua Kafka events
          - status: DRAFT → PUBLISHED → CANCELLED | COMPLETED
          - Index compound (status, start_time) phục vụ query chính:
            "events đang PUBLISHED và sắp diễn ra, sắp xếp theo start_time"
    -->

    <changeSet id="V002-create-events-table" author="ticketmaster-dev">

        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="events"/></not>
        </preConditions>

        <comment>Create events table – sự kiện (concert, show, game)</comment>

        <createTable tableName="events">

            <column name="id" type="VARCHAR(36)"
                    remarks="UUID v4, generated by application">
                <constraints primaryKey="true" nullable="false" primaryKeyName="pk_events"/>
            </column>

            <column name="name" type="VARCHAR(255)"
                    remarks="Tên sự kiện">
                <constraints nullable="false"/>
            </column>

            <column name="description" type="TEXT"
                    remarks="Mô tả chi tiết sự kiện">
                <constraints nullable="true"/>
            </column>

            <column name="venue_id" type="VARCHAR(36)"
                    remarks="FK → venues.id">
                <constraints nullable="false"
                             foreignKeyName="fk_events_venue"
                             references="venues(id)"/>
            </column>

            <column name="venue_name" type="VARCHAR(255)"
                    remarks="Denormalized venue name để tránh JOIN khi search">
                <constraints nullable="false"/>
            </column>

            <column name="start_time" type="TIMESTAMPTZ"
                    remarks="Thời điểm bắt đầu sự kiện (UTC)">
                <constraints nullable="false"/>
            </column>

            <column name="end_time" type="TIMESTAMPTZ"
                    remarks="Thời điểm kết thúc sự kiện (UTC)">
                <constraints nullable="true"/>
            </column>

            <column name="status" type="VARCHAR(20)"
                    defaultValue="DRAFT"
                    remarks="DRAFT | PUBLISHED | CANCELLED | COMPLETED">
                <constraints nullable="false"/>
            </column>

            <column name="image_url" type="VARCHAR(500)"
                    remarks="URL banner/poster">
                <constraints nullable="true"/>
            </column>

            <column name="category" type="VARCHAR(50)"
                    remarks="CONCERT | SPORT | THEATER | FESTIVAL | OTHER">
                <constraints nullable="true"/>
            </column>

            <column name="total_seats" type="INT" defaultValueNumeric="0"
                    remarks="Tổng số ghế (copy từ venue.capacity khi tạo event)">
                <constraints nullable="false"/>
            </column>

            <column name="available_seats" type="INT" defaultValueNumeric="0"
                    remarks="Số ghế còn trống – cached counter, sync từ Kafka">
                <constraints nullable="false"/>
            </column>

            <column name="created_at" type="TIMESTAMPTZ">
                <constraints nullable="false"/>
            </column>

            <column name="updated_at" type="TIMESTAMPTZ">
                <constraints nullable="false"/>
            </column>

        </createTable>

        <!-- Index chính: tìm events đang PUBLISHED sắp diễn ra -->
        <createIndex tableName="events" indexName="idx_events_status_start_time">
            <column name="status"/>
            <column name="start_time"/>
        </createIndex>

        <!-- Index cho filter theo venue -->
        <createIndex tableName="events" indexName="idx_events_venue_id">
            <column name="venue_id"/>
        </createIndex>

        <!-- Index cho filter theo category + status -->
        <createIndex tableName="events" indexName="idx_events_category_status">
            <column name="category"/>
            <column name="status"/>
        </createIndex>

        <!-- CHECK constraint status hợp lệ -->
        <sql>
            ALTER TABLE events
                ADD CONSTRAINT chk_events_status
                    CHECK (status IN ('DRAFT', 'PUBLISHED', 'CANCELLED', 'COMPLETED'));
        </sql>

        <!-- CHECK: available_seats không được âm -->
        <sql>
            ALTER TABLE events
                ADD CONSTRAINT chk_events_available_seats
                    CHECK (available_seats >= 0 AND available_seats &lt;= total_seats);
        </sql>

    </changeSet>

</databaseChangeLog>