<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!--
        Migration: V001 – Tạo bảng notifications
        Author   : ticketmaster-dev

        Design notes:
          - (user_id, created_at DESC) index: lấy notification history của user
          - (user_id, read) index: đếm/lấy unread notifications (badge count)
          - (reference_id, type) index: idempotency check trước khi tạo notification
          - (email_sent, retry_count) index: tìm notifications cần retry email
          - message length=2000: đủ cho email preview + notification message
          - email_failure_reason: lưu lỗi để debug
          - sse_pushed: track xem đã push real-time chưa (analytics)
    -->

    <changeSet id="V001-create-notifications-table" author="ticketmaster-dev">

        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="notifications"/></not>
        </preConditions>

        <comment>Create notifications table – notification history and delivery tracking</comment>

        <createTable tableName="notifications">

            <column name="id" type="VARCHAR(36)"
                    remarks="UUID v4, generated by application">
                <constraints primaryKey="true" nullable="false" primaryKeyName="pk_notifications"/>
            </column>

            <column name="user_id" type="VARCHAR(36)"
                    remarks="Logical FK → user-service users.id (recipient)">
                <constraints nullable="false"/>
            </column>

            <column name="recipient_email" type="VARCHAR(255)"
                    remarks="Email người nhận (snapshot)">
                <constraints nullable="false"/>
            </column>

            <column name="type" type="VARCHAR(30)"
                    remarks="BOOKING_CREATED | PAYMENT_PROCESSED | PAYMENT_FAILED | BOOKING_CANCELLED | BOOKING_EXPIRED | SYSTEM_ANNOUNCEMENT">
                <constraints nullable="false"/>
            </column>

            <column name="title" type="VARCHAR(255)"
                    remarks="Tiêu đề notification (email subject / SSE title)">
                <constraints nullable="false"/>
            </column>

            <column name="message" type="VARCHAR(2000)"
                    remarks="Nội dung text thuần (preview / fallback)">
                <constraints nullable="false"/>
            </column>

            <column name="reference_id" type="VARCHAR(36)"
                    remarks="ID entity liên quan (bookingId, transactionId)">
                <constraints nullable="true"/>
            </column>

            <column name="reference_type" type="VARCHAR(30)"
                    remarks="Loại entity: BOOKING | TRANSACTION | EVENT">
                <constraints nullable="true"/>
            </column>

            <column name="email_sent" type="BOOLEAN"
                    defaultValueBoolean="false"
                    remarks="true nếu email đã gửi thành công">
                <constraints nullable="false"/>
            </column>

            <column name="sse_pushed" type="BOOLEAN"
                    defaultValueBoolean="false"
                    remarks="true nếu đã push qua SSE real-time">
                <constraints nullable="false"/>
            </column>

            <column name="read" type="BOOLEAN"
                    defaultValueBoolean="false"
                    remarks="true nếu user đã đọc notification này">
                <constraints nullable="false"/>
            </column>

            <column name="email_failure_reason" type="VARCHAR(500)"
                    remarks="Lý do gửi email thất bại (null nếu thành công)">
                <constraints nullable="true"/>
            </column>

            <column name="retry_count" type="SMALLINT"
                    defaultValue="0"
                    remarks="Số lần retry gửi email (tối đa 3)">
                <constraints nullable="false"/>
            </column>

            <column name="created_at" type="TIMESTAMPTZ">
                <constraints nullable="false"/>
            </column>

            <column name="updated_at" type="TIMESTAMPTZ">
                <constraints nullable="false"/>
            </column>

        </createTable>

        <!-- Index: notification history của user (newest first) -->
        <createIndex tableName="notifications" indexName="idx_notifications_user_created">
            <column name="user_id"/>
            <column name="created_at" descending="true"/>
        </createIndex>

        <!-- Index: unread notifications (badge count query) -->
        <createIndex tableName="notifications" indexName="idx_notifications_user_unread">
            <column name="user_id"/>
            <column name="read"/>
        </createIndex>

        <!-- Index: idempotency check (reference_id + type unique per delivery) -->
        <createIndex tableName="notifications" indexName="idx_notifications_ref_type">
            <column name="reference_id"/>
            <column name="type"/>
        </createIndex>

        <!-- Index: find failed emails that can be retried -->
        <createIndex tableName="notifications" indexName="idx_notifications_email_retry">
            <column name="email_sent"/>
            <column name="retry_count"/>
        </createIndex>

        <!-- CHECK: type hợp lệ -->
        <sql>
            ALTER TABLE notifications
            ADD CONSTRAINT chk_notifications_type
            CHECK (type IN (
                'BOOKING_CREATED', 'PAYMENT_PROCESSED', 'PAYMENT_FAILED',
                'BOOKING_CANCELLED', 'BOOKING_EXPIRED', 'SYSTEM_ANNOUNCEMENT'
            ));
        </sql>

        <!-- CHECK: retry_count không âm và không vượt quá 3 -->
        <sql>
            ALTER TABLE notifications
            ADD CONSTRAINT chk_notifications_retry_count
            CHECK (retry_count >= 0 AND retry_count &lt;= 3);
        </sql>

    </changeSet>

</databaseChangeLog>