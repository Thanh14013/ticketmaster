<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!--
        Migration: V001 – Tạo bảng transactions
        Author   : ticketmaster-dev

        Design notes:
          - booking_id UNIQUE → idempotency constraint: mỗi booking chỉ có 1 transaction
          - PaymentMethod embedded dưới dạng cột pm_* (Value Object, không tạo table riêng)
          - stripe_* columns: reference IDs từ Stripe API để trace và refund
          - failure_* columns: lưu lý do thất bại từ Stripe (card_declined, etc.)
          - Index (status, created_at): Quartz reconciliation query cho PROCESSING > 5 phút
          - Index user_id: lấy payment history của user nhanh
    -->

    <changeSet id="V001-create-transactions-table" author="ticketmaster-dev">

        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="transactions"/></not>
        </preConditions>

        <comment>Create transactions table – payment aggregate root</comment>

        <createTable tableName="transactions">

            <!-- Primary Key -->
            <column name="id" type="VARCHAR(36)"
                    remarks="UUID v4, generated by application (no auto-increment)">
                <constraints primaryKey="true" nullable="false" primaryKeyName="pk_transactions"/>
            </column>

            <!-- Business References -->
            <column name="booking_id" type="VARCHAR(36)"
                    remarks="FK logic → booking-service bookings.id | UNIQUE = idempotency">
                <constraints nullable="false" unique="true"
                             uniqueConstraintName="uq_transactions_booking_id"/>
            </column>

            <column name="user_id" type="VARCHAR(36)"
                    remarks="FK logic → user-service users.id">
                <constraints nullable="false"/>
            </column>

            <column name="user_email" type="VARCHAR(255)"
                    remarks="Snapshot email để gửi notification – không join user-service">
                <constraints nullable="true"/>
            </column>

            <!-- Amount -->
            <column name="amount" type="DECIMAL(10,2)"
                    remarks="Số tiền thanh toán (phải > 0)">
                <constraints nullable="false"/>
            </column>

            <column name="currency" type="VARCHAR(3)"
                    defaultValue="USD"
                    remarks="ISO 4217 currency code (USD, VND, etc.)">
                <constraints nullable="false"/>
            </column>

            <!-- State Machine -->
            <column name="status" type="VARCHAR(20)"
                    defaultValue="PENDING"
                    remarks="PENDING | PROCESSING | SUCCEEDED | FAILED | CANCELLED | REFUNDED">
                <constraints nullable="false"/>
            </column>

            <!-- PaymentMethod (embedded Value Object) -->
            <column name="pm_stripe_id" type="VARCHAR(100)"
                    remarks="Stripe Payment Method ID (pm_xxx)">
                <constraints nullable="true"/>
            </column>

            <column name="pm_type" type="VARCHAR(20)"
                    remarks="Payment method type: card | bank_transfer | paypal">
                <constraints nullable="true"/>
            </column>

            <column name="pm_card_brand" type="VARCHAR(20)"
                    remarks="Card brand: visa | mastercard | amex | jcb">
                <constraints nullable="true"/>
            </column>

            <column name="pm_card_last4" type="VARCHAR(4)"
                    remarks="Last 4 digits of card – PCI-DSS compliant, never full number">
                <constraints nullable="true"/>
            </column>

            <column name="pm_exp_month" type="INTEGER"
                    remarks="Card expiration month (1-12)">
                <constraints nullable="true"/>
            </column>

            <column name="pm_exp_year" type="INTEGER"
                    remarks="Card expiration year (e.g. 2026)">
                <constraints nullable="true"/>
            </column>

            <!-- Stripe References -->
            <column name="stripe_payment_intent_id" type="VARCHAR(100)"
                    remarks="Stripe PaymentIntent ID (pi_xxx) – set when intent created">
                <constraints nullable="true"/>
            </column>

            <column name="stripe_charge_id" type="VARCHAR(100)"
                    remarks="Stripe Charge ID (ch_xxx) – set when charge succeeds, used for refund">
                <constraints nullable="true"/>
            </column>

            <column name="stripe_refund_id" type="VARCHAR(100)"
                    remarks="Stripe Refund ID (re_xxx) – set when refund succeeds">
                <constraints nullable="true"/>
            </column>

            <!-- Failure Details -->
            <column name="failure_code" type="VARCHAR(100)"
                    remarks="Stripe error code (card_declined, insufficient_funds, etc.)">
                <constraints nullable="true"/>
            </column>

            <column name="failure_message" type="VARCHAR(500)"
                    remarks="Human-readable failure description from Stripe">
                <constraints nullable="true"/>
            </column>

            <!-- Audit -->
            <column name="created_at" type="TIMESTAMPTZ"
                    remarks="Transaction creation timestamp (UTC)">
                <constraints nullable="false"/>
            </column>

            <column name="updated_at" type="TIMESTAMPTZ"
                    remarks="Last status update timestamp (UTC)">
                <constraints nullable="false"/>
            </column>

        </createTable>

        <!-- Indexes for query performance -->

        <!-- Reconciliation: find PROCESSING transactions older than 5 minutes -->
        <createIndex tableName="transactions"
                     indexName="idx_transactions_status_created">
            <column name="status"/>
            <column name="created_at"/>
        </createIndex>

        <!-- Payment history for a user -->
        <createIndex tableName="transactions"
                     indexName="idx_transactions_user_id">
            <column name="user_id"/>
        </createIndex>

        <!-- Lookup by Stripe PaymentIntent ID (for webhook handling) -->
        <createIndex tableName="transactions"
                     indexName="idx_transactions_stripe_intent_id">
            <column name="stripe_payment_intent_id"/>
        </createIndex>

    </changeSet>

</databaseChangeLog>

