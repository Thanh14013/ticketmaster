<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!--
        Migration: V001 – Tạo bảng bookings
        Author   : ticketmaster-dev

        Design notes:
          - user_email snapshot để gửi notification không cần join user-service
          - event_name snapshot để hiển thị history không cần join event-service
          - expires_at = created_at + 2 phút → Quartz query expired bookings
          - status index + expires_at: Quartz query "PENDING_PAYMENT và đã hết hạn"
          - transaction_id: ID từ Stripe sau khi payment thành công
    -->

    <changeSet id="V001-create-bookings-table" author="ticketmaster-dev">

        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="bookings"/></not>
        </preConditions>

        <comment>Create bookings table – core booking aggregate</comment>

        <createTable tableName="bookings">

            <column name="id" type="VARCHAR(36)"
                    remarks="UUID v4, generated by application">
                <constraints primaryKey="true" nullable="false" primaryKeyName="pk_bookings"/>
            </column>

            <column name="user_id" type="VARCHAR(36)"
                    remarks="FK logic → users.id (cross-service, no physical FK)">
                <constraints nullable="false"/>
            </column>

            <column name="user_email" type="VARCHAR(255)"
                    remarks="Snapshot email để gửi notification">
                <constraints nullable="false"/>
            </column>

            <column name="event_id" type="VARCHAR(36)"
                    remarks="FK logic → event-service events.id">
                <constraints nullable="false"/>
            </column>

            <column name="event_name" type="VARCHAR(255)"
                    remarks="Snapshot tên event để hiển thị history">
                <constraints nullable="false"/>
            </column>

            <column name="total_amount" type="DECIMAL(10,2)"
                    remarks="Tổng tiền = sum(booking_items.price)">
                <constraints nullable="false"/>
            </column>

            <column name="status" type="VARCHAR(20)"
                    defaultValue="PENDING_PAYMENT"
                    remarks="PENDING_PAYMENT | CONFIRMED | CANCELLED | EXPIRED">
                <constraints nullable="false"/>
            </column>

            <column name="transaction_id" type="VARCHAR(100)"
                    remarks="Stripe transaction ID (null khi chưa payment)">
                <constraints nullable="true"/>
            </column>

            <column name="cancellation_reason" type="VARCHAR(500)"
                    remarks="Lý do huỷ (null nếu không bị cancel)">
                <constraints nullable="true"/>
            </column>

            <column name="expires_at" type="TIMESTAMPTZ"
                    remarks="created_at + seat_lock_ttl_minutes – dùng bởi Quartz scheduler">
                <constraints nullable="false"/>
            </column>

            <column name="created_at" type="TIMESTAMPTZ">
                <constraints nullable="false"/>
            </column>

            <column name="updated_at" type="TIMESTAMPTZ">
                <constraints nullable="false"/>
            </column>

        </createTable>

        <!-- Index: booking history của user -->
        <createIndex tableName="bookings" indexName="idx_bookings_user_id">
            <column name="user_id"/>
            <column name="created_at" descending="true"/>
        </createIndex>

        <!-- Index: Quartz query expired bookings -->
        <createIndex tableName="bookings" indexName="idx_bookings_status_expires">
            <column name="status"/>
            <column name="expires_at"/>
        </createIndex>

        <!-- Index: kiểm tra duplicate booking (user + event) -->
        <createIndex tableName="bookings" indexName="idx_bookings_user_event">
            <column name="user_id"/>
            <column name="event_id"/>
        </createIndex>

        <!-- CHECK: status hợp lệ -->
        <sql>
            ALTER TABLE bookings
            ADD CONSTRAINT chk_bookings_status
            CHECK (status IN ('PENDING_PAYMENT', 'CONFIRMED', 'CANCELLED', 'EXPIRED'));
        </sql>

        <!-- CHECK: total_amount không âm -->
        <sql>
            ALTER TABLE bookings
            ADD CONSTRAINT chk_bookings_total_amount
            CHECK (total_amount >= 0);
        </sql>

    </changeSet>

</databaseChangeLog>